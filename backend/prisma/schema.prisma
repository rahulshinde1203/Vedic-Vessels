generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ─── Enums ───────────────────────────────���───────────────────────────���────────

enum Role {
  USER
  ADMIN
}

enum OrderStatus {
  PENDING
  SHIPPED
  DELIVERED
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
}

// ─── Models ────────────────────────────────���───────────────────────────��──────

model User {
  id        Int      @id @default(autoincrement())
  name      String?
  phone     String   @unique
  email     String?
  role      Role     @default(USER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  orders          Order[]
  addresses       Address[]
  supportTickets  SupportTicket[]

  @@map("users")
}

model Category {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  products Product[]

  @@map("categories")
}

model Product {
  id              Int      @id @default(autoincrement())
  name            String
  description     String?  @db.Text
  mrp             Decimal  @db.Decimal(10, 2) @default(0)
  price           Decimal  @db.Decimal(10, 2)
  discountPercent Decimal  @db.Decimal(5, 2)  @default(0) @map("discount_percent")
  stock           Int      @default(0)
  imageUrl        String?  @map("image_url")
  images          Json     @default("[]")
  isActive        Boolean  @default(true)
  categoryId      Int      @map("category_id")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  category   Category    @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  orderItems OrderItem[]

  @@unique([name, categoryId])
  @@index([name])
  @@index([categoryId])
  @@index([categoryId, name])
  @@map("products")
}

model Address {
  id        Int      @id @default(autoincrement())
  userId    Int      @map("user_id")
  fullName  String   @map("full_name")
  phone     String
  address   String   @db.Text
  city      String
  state     String
  pincode   String
  createdAt DateTime @default(now())

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  orders Order[]

  @@index([userId])
  @@map("addresses")
}

model Order {
  id              Int         @id @default(autoincrement())
  userId          Int         @map("user_id")
  addressId       Int?        @map("address_id")
  totalAmount     Decimal     @db.Decimal(10, 2) @map("total_amount")
  deliveryAddress String?     @db.Text @map("delivery_address")
  status          OrderStatus @default(PENDING)
  trackingId      String?     @map("tracking_id")
  courierName     String?     @map("courier_name")
  trackingUrl     String?     @map("tracking_url")
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  user           User            @relation(fields: [userId], references: [id], onDelete: Restrict)
  address        Address?        @relation(fields: [addressId], references: [id], onDelete: Restrict)
  orderItems     OrderItem[]
  supportTickets SupportTicket[]

  @@index([userId])
  @@index([addressId])
  @@index([status])
  @@index([createdAt])
  @@map("orders")
}

model OrderItem {
  id        Int     @id @default(autoincrement())
  orderId   Int     @map("order_id")
  productId Int     @map("product_id")
  quantity  Int     @default(1)
  price     Decimal @db.Decimal(10, 2)

  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Restrict)

  @@index([orderId])
  @@index([productId])
  @@map("order_items")
}

model SupportTicket {
  id        Int          @id @default(autoincrement())
  userId    Int          @map("user_id")
  orderId   Int?         @map("order_id")
  subject   String
  message   String       @db.Text
  status    TicketStatus @default(OPEN)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  user    User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  order   Order?         @relation(fields: [orderId], references: [id], onDelete: SetNull)
  replies SupportReply[]

  @@index([userId])
  @@index([status])
  @@index([orderId])
  @@map("support_tickets")
}

model SupportReply {
  id        Int      @id @default(autoincrement())
  ticketId  Int      @map("ticket_id")
  message   String   @db.Text
  isAdmin   Boolean  @default(false) @map("is_admin")
  createdAt DateTime @default(now())

  ticket SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@index([ticketId])
  @@map("support_replies")
}
